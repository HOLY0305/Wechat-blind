<Window x:Class="WechatBlind.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WechatBlind.UI"
        x:ClassModifier="internal"
        Title="隐私遮罩 - 设置"
        Width="560" Height="520"
        MinWidth="480" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False"
        Background="#F5F5F7">

    <Window.Resources>
        <local:PatternToImageSourceConverter x:Key="PatternToImage"/>

        <!-- iOS 风格 ToggleButton -->
        <Style x:Key="ToggleSwitch" TargetType="ToggleButton">
            <Setter Property="Width" Value="52"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="Track" CornerRadius="15"
                                    Width="52" Height="30"
                                    Background="#E0E0E0"/>
                            <Border x:Name="Thumb" CornerRadius="12"
                                    Width="26" Height="26"
                                    Background="White" Margin="2,0,0,0"
                                    HorizontalAlignment="Left">
                                <Border.Effect>
                                    <DropShadowEffect ShadowDepth="0" BlurRadius="3" Opacity="0.2"/>
                                </Border.Effect>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#34C759"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,2,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="20,14"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="4" Opacity="0.08" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#323232"/>
        </Style>

        <Style x:Key="CardDesc" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#B4B4B4"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>

        <Style x:Key="SliderLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="#B4B4B4"/>
        </Style>

        <Style x:Key="ValueLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#323232"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="50"/>
            <Setter Property="TextAlignment" Value="Right"/>
        </Style>

        <Style x:Key="GreenButton" TargetType="Button">
            <Setter Property="Background" Value="#34C759"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2DB84E"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#28A344"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GrayButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#787878"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#DCDCDC"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F5F5F5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EBEBEB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DestructiveButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#DC3232"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#DCC8C8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FFF0F0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FFE0E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Slider 样式美化 -->
        <Style TargetType="Slider">
            <Setter Property="Height" Value="28"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 可滚动内容区 -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="24,16,24,0">
            <StackPanel MaxWidth="520" HorizontalAlignment="Stretch">

                <!-- 启用遮罩 -->
                <Border Style="{StaticResource CardBorder}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="启用遮罩" Style="{StaticResource CardTitle}"/>
                            <TextBlock Text="在目标窗口顶部显示遮罩，防止他人窥视" Style="{StaticResource CardDesc}"/>
                        </StackPanel>
                        <ToggleButton x:Name="TglEnabled" Grid.Column="1"
                                      Style="{StaticResource ToggleSwitch}"
                                      VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- 遮罩透明度 -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="遮罩透明度" Style="{StaticResource CardTitle}"/>
                        <TextBlock Text="调整遮罩的透明程度" Style="{StaticResource CardDesc}"/>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="SldOpacity" Grid.Column="0"
                                    Minimum="0" Maximum="100" TickFrequency="1"
                                    IsSnapToTickEnabled="False" TickPlacement="None"
                                    VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock x:Name="LblOpacity" Grid.Column="1"
                                       Text="70%" Style="{StaticResource ValueLabel}"/>
                        </Grid>
                        <Grid Margin="0,4,0,0">
                            <TextBlock Text="透明" Style="{StaticResource SliderLabel}"/>
                            <TextBlock Text="不透明" Style="{StaticResource SliderLabel}"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 模糊程度 -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="模糊程度" Style="{StaticResource CardTitle}"/>
                        <TextBlock Text="调整遮罩的模糊效果" Style="{StaticResource CardDesc}"/>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="SldBlur" Grid.Column="0"
                                    Minimum="0" Maximum="100" TickFrequency="1"
                                    IsSnapToTickEnabled="False" TickPlacement="None"
                                    VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock x:Name="LblBlur" Grid.Column="1"
                                       Text="50%" Style="{StaticResource ValueLabel}"/>
                        </Grid>
                        <Grid Margin="0,4,0,0">
                            <TextBlock Text="清晰" Style="{StaticResource SliderLabel}"/>
                            <TextBlock Text="模糊" Style="{StaticResource SliderLabel}"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 遮罩图案 -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="遮罩图案" Style="{StaticResource CardTitle}"/>
                        <TextBlock Text="选择或自定义遮罩的图案效果" Style="{StaticResource CardDesc}"/>
                        <ItemsControl x:Name="PatternGrid" Margin="0,10,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Tag" Value="{Binding}"/>
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Width="56" Margin="0,0,8,4"
                                                Cursor="Hand" Tag="{Binding}"
                                                MouseLeftButtonDown="OnPatternClick">
                                        <Border x:Name="PreviewBorder" Width="48" Height="48"
                                                Background="#F0F0F0" CornerRadius="4"
                                                BorderThickness="2" BorderBrush="Transparent">
                                            <Image Source="{Binding Converter={StaticResource PatternToImage}}"
                                                   Width="44" Height="44" Stretch="Uniform"
                                                   Margin="2"/>
                                        </Border>
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="10" Foreground="#787878"
                                                   HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="+ 添加图案" Style="{StaticResource GrayButton}"
                                    Click="OnUploadPattern" Margin="0,0,8,0"/>
                            <Button x:Name="BtnDeletePattern" Content="删除图案"
                                    Style="{StaticResource DestructiveButton}"
                                    Click="OnDeletePattern" IsEnabled="False"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 快捷键 -->
                <Border Style="{StaticResource CardBorder}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="快捷键" Style="{StaticResource CardTitle}"/>
                            <TextBlock Text="设置启用/禁用遮罩的快捷键" Style="{StaticResource CardDesc}"/>
                        </StackPanel>
                        <Button x:Name="BtnHotkey" Grid.Column="1"
                                Style="{StaticResource GrayButton}"
                                MinWidth="120" Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                Click="OnHotkeyClick"/>
                        <Button Content="修改" Grid.Column="2"
                                Style="{StaticResource GreenButton}"
                                VerticalAlignment="Center"
                                Click="OnHotkeyClick"/>
                    </Grid>
                </Border>

                <!-- 开机自启动 -->
                <Border Style="{StaticResource CardBorder}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="开机自启动" Style="{StaticResource CardTitle}"/>
                            <TextBlock Text="系统启动时自动运行隐私遮罩" Style="{StaticResource CardDesc}"/>
                        </StackPanel>
                        <ToggleButton x:Name="TglAutoStart" Grid.Column="1"
                                      Style="{StaticResource ToggleSwitch}"
                                      VerticalAlignment="Center"/>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- 底部按钮栏 -->
        <Border Grid.Row="1" Background="#F5F5F7" Padding="24,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Style="{StaticResource GrayButton}"
                        Margin="0,0,10,0" Click="OnCancel"/>
                <Button Content="确定" Style="{StaticResource GreenButton}"
                        Click="OnSave"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
